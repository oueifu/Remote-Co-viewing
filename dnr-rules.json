[
  {
    "id": 1,
    "priority": 1,
    "action": {
      "type": "modifyHeaders",
      "requestHeaders": [
        {
          "header": "referer",
          "operation": "set",
          "value": "https://www.bilibili.com/"
        },
        {
          "header": "origin",
          "operation": "set",
          "value": "https://www.bilibili.com"
        }
      ]
    },
    "condition": {
      "regexFilter": "^https://([a-z0-9-]+\\.)?(bilivideo|bilibili)\\.com/.*",
      "resourceTypes": [
        "media",
        "xmlhttprequest"
      ]
    }
  }
]
